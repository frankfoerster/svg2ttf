{
  "name": "@frankfoerster/svg2ttf",
  "version": "6.1.0",
  "description": "Converts SVG font to TTF font",
  "keywords": [
    "convertor",
    "font",
    "svg",
    "ttf"
  ],
  "license": "MIT",
  "author": "Sergey Batishchev <sergej.batishchev@gmail.com>",
  "maintainers": [
    "Frank Förster"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/frankfoerster/svg2ttf.git"
  },
  "bin": {
    "svg2ttf": "./dist/svg2ttf.mjs"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "test": "npm run lint && vitest run",
    "update_fixture": "node ./dist/svg2ttf.mjs --ts 1457357570703 test/fixtures/test.svg test/fixtures/test.ttf"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.9",
    "argparse": "^2.0.1",
    "cubic2quad": "^1.2.1",
    "microbuffer": "^1.0.0",
    "svgpath": "^2.6.0"
  },
  "devDependencies": {
    "@types/argparse": "^2.0.17",
    "@types/node": "^25.6.0",
    "opentype.js": "^1.3.4",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
